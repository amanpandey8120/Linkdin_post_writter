# Model paths
LORA_ADAPTER_PATH=linkedin_post_writer_lora
BASE_MODEL_NAME=unsloth/qwen3-8b-unsloth-bnb-4bit

# Generation defaults
MAX_NEW_TOKENS=512
TEMPERATURE=0.7
TOP_P=0.9
TOP_K=50
REPETITION_PENALTY=1.1

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Hardware
DEVICE_MAP=auto
TORCH_DTYPE=float16
